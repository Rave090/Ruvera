{
  "expo": {
    "name": "Ruvera",
    "slug": "Ruvera",
    "version": "1.0.0",
    "scheme": "ruvera",
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Ruvera to use your camera for skin analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ruvera to access your photos for skin analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
